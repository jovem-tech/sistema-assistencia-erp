NODE_ENV=production
HOST=0.0.0.0
PORT=3001

# Token interno usado entre ERP e gateway Node
API_TOKEN=troque-por-um-token-forte

# Origem permitida para consumir o gateway (pode listar varias separadas por virgula)
ERP_ORIGIN=https://erp.seudominio.com,https://crm.seudominio.com

# Persistencia da sessao do WhatsApp
WHATSAPP_SESSION_PATH=./.wwebjs_auth
# Alias compativel para ambientes Linux (se preferir usar SESSION_PATH)
SESSION_PATH=./.wwebjs_auth
WHATSAPP_CLIENT_ID=erp-local-gateway
LOGS_DIR=./logs

# Webhook inbound para ERP (mensagens recebidas -> /webhooks/whatsapp)
ERP_WEBHOOK_URL=https://erp.seudominio.com/webhooks/whatsapp
ERP_WEBHOOK_TOKEN=troque-por-token-do-webhook-erp
FORWARD_INBOUND_ENABLED=1
ERP_WEBHOOK_TIMEOUT_MS=10000
FORWARD_INBOUND_MEDIA_ENABLED=1
INBOUND_MEDIA_MAX_BYTES=5242880

# Operacao
RECONNECT_DELAY_MS=5000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
REQUEST_TIMEOUT_MS=30000

# Opcional (Windows): caminho do Chrome para evitar falha "spawn EPERM"
CHROME_EXECUTABLE_PATH=
